# ============================================================
# FRONTEND (Vite) ENVIRONMENT
# ============================================================
# Only PUBLIC values may live here — Vite inlines anything that
# starts with VITE_ into the browser bundle.
#
# NEVER put DEENCORE / Quran Foundation client secrets in this file.
# Those belong only in the backend (DEENCORE/server/.env locally,
# Render env vars in production).
#
# Usage:
#   cp .env.example .env.local   (gitignored — for local dev overrides)
#   In Vercel, set VITE_API_URL in Project → Settings → Environment Variables.
#
# Behavior:
# - If VITE_API_URL is set, the frontend hits that URL for every /api/* call.
# - If it is empty, the frontend assumes same-origin (works for the
#   combined backend+frontend deploy where Express serves dist/).
# - In local `npm run dev`, the frontend falls back to http://<host>:3001
#   automatically, so VITE_API_URL is optional during development.

# Example for split deploy (Vercel frontend + Render backend):
# VITE_API_URL=https://deencore-backend.onrender.com

VITE_API_URL=
