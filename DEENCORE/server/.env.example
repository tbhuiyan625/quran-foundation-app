# ============================================================
# BACKEND (Express) ENVIRONMENT — Render uses these as env vars
# ============================================================
# Get DEENCORE credentials from:
#   https://api-docs.quran.foundation/request-access
#
# Locally:
#   cp DEENCORE/server/.env.example DEENCORE/server/.env    (gitignored)
#
# In Render:
#   Service → Environment → Environment Variables
#   Set the same keys here — DO NOT commit real values.
#
# SECURITY:
# - Never expose QF_CLIENT_ID / QF_CLIENT_SECRET to the frontend.
# - The frontend only ever sees the public Render URL via VITE_API_URL.

# --- Required: DEENCORE OAuth2 credentials ---
QF_CLIENT_ID=your_client_id_here
QF_CLIENT_SECRET=your_client_secret_here

# --- Optional: API endpoints ---
# Pre-live (most hackathon credentials):
QF_AUTH_URL=https://prelive-oauth2.quran.foundation
QF_API_BASE=https://apis-prelive.quran.foundation
# Production (uncomment if your credentials are for production):
# QF_AUTH_URL=https://oauth2.quran.foundation
# QF_API_BASE=https://apis.quran.foundation

# --- Optional: manual token override (debug only) ---
# QF_ACCESS_TOKEN=

# --- Server settings ---
# Render assigns PORT automatically; locally we default to 3001.
PORT=3001

# CORS allowlist (comma-separated). Use "*" or leave empty to allow all origins.
# In production, set this to your Vercel domain(s):
# CORS_ORIGIN=https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=*
