# ============================================================
# BACKEND CREDENTIALS - NEVER EXPOSE THESE TO FRONTEND
# ============================================================
# Get your credentials from: https://api-docs.quran.foundation/request-access
# 
# OAuth2 Client Credentials Flow:
# 1. Request access at https://api-docs.quran.foundation/request-access
# 2. Fill out the form with your app details
# 3. Wait for approval (usually 24-48 hours)
# 4. You'll receive QF_CLIENT_ID and QF_CLIENT_SECRET
# 5. Copy this file to server/.env and fill in your credentials
# 6. NEVER commit server/.env to git (it contains secrets!)
#
# Optional:
# - QF_AUTH_URL: OAuth2 token endpoint (defaults to production)
# - QF_API_BASE: DEENCORE API base URL (defaults to production)
# Use prelive URLs for testing/staging environment
#
# The backend will:
# - Use these credentials to request an OAuth2 access token
# - Cache the token until near expiry
# - Automatically refresh the token when needed
# - Send the token securely to DEENCORE Content API

QF_CLIENT_ID=your_client_id_here
QF_CLIENT_SECRET=your_client_secret_here
QF_AUTH_URL=https://auth.quran.foundation
QF_API_BASE=https://apis.quran.foundation
PORT=3001

